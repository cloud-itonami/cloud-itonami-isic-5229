{:paths ["src"]
 ;; langgraph brings langchain transitively (both zero-/single-dep,
 ;; all .cljc -> portable to JVM / SCI / ClojureScript / GraalVM). It lives
 ;; in the kotoba-lang org of this workspace (transferred + renamed from
 ;; com-junkawasaki/langgraph-clj / com-junkawasaki/langchain-clj).
 ;;
 ;; This freight-forwarding/customs-brokerage vertical is an OPERATIONS
 ;; COORDINATION actor (freight-forwarding/customs-documentation data
 ;; logging, routing/consolidation scheduling proposals, customs-
 ;; documentation/regulatory-compliance-concern flagging,
 ;; carrier-booking coordination) -- it never itself holds
 ;; customs-clearance or shipment-release authority (see
 ;; `freightforwarding.governor`'s `finalize-clearance-violations`: any
 ;; proposal to directly finalize a customs-clearance or shipment-
 ;; release decision is a hard, permanent block, and the closed
 ;; op-allowlist contains no such op in the first place). This repo is
 ;; standalone (forkable outside the workspace); the :local/root paths
 ;; only resolve inside the monorepo checkout -- a standalone fork
 ;; should override them with git coordinates.
 :deps {io.github.kotoba-lang/langgraph
        {:local/root "../../kotoba-lang/langgraph"}
        ;; shared langchain.db store seam (EDN-blob codec + identity
        ;; schema + field-spec entity helpers) -- this store is an
        ;; entity-store adopter (ADR-2607141600), NOT a hand-rolled
        ;; enc/dec* copy.
        io.github.kotoba-lang/langchain-store
        {:local/root "../../kotoba-lang/langchain-store"}}
 :aliases
 {;; offline workspace dev -- pin transitive langchain to local checkout
  :dev {:override-deps
        {io.github.kotoba-lang/langchain
         {:local/root "../../kotoba-lang/langchain"}}}
  ;; clojure -M:dev:run  -> drive the demo through one OperationActor
  :run {:main-opts ["-m" "freightforwarding.sim"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; static analysis -- clj-kondo from deps (no binary), errors fail CI.
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main"
                        "--lint" "src" "test"
                        "--fail-level" "error"]}}}
